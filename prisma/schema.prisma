// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  email     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  phone     String?
  role      String   @default("user")
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings     Booking[]
  transactions Transaction[]

  @@map("profiles")
}

model RoomType {
  id           Int     @id @default(autoincrement())
  name         String
  description  String?
  capacity     Int
  pricePerHour Decimal @map("price_per_hour") @db.Decimal(10, 2)
  imageUrl     String? @map("image_url")

  rooms Room[]

  @@map("room_types")
}

model Room {
  id          Int     @id @default(autoincrement())
  name        String
  typeId      Int     @map("type_id")
  description String?
  isActive    Boolean @default(true) @map("is_active")

  roomType RoomType  @relation(fields: [typeId], references: [id])
  bookings Booking[]

  @@map("rooms")
}

model TimeSlot {
  id        Int     @id @default(autoincrement())
  startTime String  @map("start_time") // Using string for simple HH:mm
  endTime   String  @map("end_time")
  label     String?

  bookings Booking[]

  @@map("time_slots")
}

model Booking {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  roomId      Int      @map("room_id")
  timeSlotId  Int      @map("time_slot_id")
  bookingDate DateTime @map("booking_date") @db.Date
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)
  status      String   @default("confirmed") // confirmed, cancelled, pending
  createdAt   DateTime @default(now()) @map("created_at")

  user     Profile  @relation(fields: [userId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id])

  @@map("bookings")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  amount      Decimal  @db.Decimal(10, 2)
  type        String // topup, payment, refund
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id])

  @@map("transactions")
}
